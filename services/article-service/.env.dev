SPRING_PROFILES_ACTIVE=dev
TYPOO_ARTICLE_PORT=8081
# Локальное подключение к Postgres (поднят через docker-compose)
TYPOO_ARTICLE_DB_NAME=typoo_article_db
TYPOO_ARTICLE_DB_URL=jdbc:postgresql://localhost:5435/typoo_article_db
TYPOO_ARTICLE_DB_USERNAME=typoo_db_user
TYPOO_ARTICLE_DB_PASSWORD=typoo_db_pass